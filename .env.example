# Akasha Universal Library - Environment Configuration

# 1. AI & LLM Configuration
# Use 'gpt-4o-mini' for cloud-based reasoning or local LLM URLs
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-key-here

# 2. Infrastructure Endpoints
CHROMA_HOST=localhost
CHROMA_PORT=8000

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=akasha_password

# 3. Web3 & Distributed Storage
ARWEAVE_JWK=local_key.json
OUROBOROS_API_URL=http://localhost:8545

# 4. Multimodal & S3
MINIO_ROOT_USER=akasha_admin
MINIO_ROOT_PASSWORD=akasha_password
S3_ENDPOINT=http://localhost:9000

# 5. Application Ports
BACKEND_PORT=8000
FRONTEND_PORT=4200
